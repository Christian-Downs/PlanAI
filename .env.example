# PlanAI - Environment Variables
# Copy this to .env.local and fill in your values

# Database - Neon Serverless Postgres
# Get these from https://console.neon.tech → your project → Connection Details
# Pooled connection (for Prisma Client queries via serverless driver)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Direct connection (for Prisma Migrate / prisma db push)
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Google OAuth (Calendar + Gmail)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth (Outlook)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# OpenAI API Key (for LLM features)
OPENAI_API_KEY=""

# Optional: Anthropic as alternative LLM
ANTHROPIC_API_KEY=""

# Webhook verification tokens
GOOGLE_WEBHOOK_TOKEN=""
OUTLOOK_WEBHOOK_TOKEN=""

# App URL (for webhook callbacks)
APP_URL="http://localhost:3000"

# LMS Credentials (user-provided, stored encrypted)
# These are template env vars - actual credentials come from user input
